{
  "name": "iot_microservices-master",
  "version": "1.0.0",
  "description": "You may check the web application at: https://iot-microservices.eu-gb.mybluemix.net.",
  "main": "test_api.js",
  "scripts": {
    "test": "npm run test:microcontrollers && npm run test:orchestrator && npm run test:measure && npm run test:publisher && npm run test:stats && npm run test:ai && npm run test:auth",
    "test:microcontrollers": "cd microcontrollers-ms && npm test",
    "test:orchestrator": "cd orchestrator-ms && npm test",
    "test:measure": "cd measure-ms && npm test",
    "test:publisher": "cd publisher-ms && npm test",
    "test:stats": "cd stats-ms && pytest",
    "test:ai": "cd ai-ms && export PYTHONPATH=src && pytest",
    "test:auth": "cd auth-ms/src && go test ./... -cover",
    "test:integration": "cd integration-tests && npm test",
    "test:e2e": "docker-compose -f docker-compose.test.yml up --build --exit-code-from integration-tests",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  }
}